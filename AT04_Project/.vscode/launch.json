{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Pytest (Current File)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [
        "-s",
        "${file}"
      ],
      "console": "integratedTerminal"
    }
  ]
}